<div style="margin-bottom: 15px; text-align: <%= defined?(@property) ? 'right' : 'left' %>;">
  <% if params[:is_admin] == "true" %>
    <% toggle_path = defined?(@property) ? listing_path(@property, request.query_parameters.except(:is_admin)) : listings_path(request.query_parameters.except(:is_admin)) %>
    <%= link_to "Switch to User View", toggle_path, class: "btn btn-sm btn-secondary" %>
  <% else %>
    <% toggle_path = defined?(@property) ? listing_path(@property, request.query_parameters.merge(is_admin: true)) : listings_path(request.query_parameters.merge(is_admin: true)) %>
    <%= link_to "Switch to Admin View", toggle_path, class: "btn btn-sm btn-primary" %>
  <% end %>
</div>